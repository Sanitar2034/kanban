#!/bin/sh

STAGED_FILES=$(git diff --cached --name-only)

echo "Running biome check on staged files..."
npx biome check --staged --no-errors-on-unmatched --files-ignore-unknown=true
if [ $? -ne 0 ]; then
	echo "Biome check failed."
	exit 1
fi

echo "Running type checking..."
npm run typecheck
if [ $? -ne 0 ]; then
	echo "Root type checking failed."
	exit 1
fi

echo "Running web-ui type checking..."
npm run web:typecheck
if [ $? -ne 0 ]; then
	echo "Web UI type checking failed."
	exit 1
fi

for file in $STAGED_FILES; do
	if [ -f "$file" ]; then
		git add "$file"
	fi
done

echo "Pre-commit checks passed."
